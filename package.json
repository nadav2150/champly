{
  "name": "champty",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "react-router typegen && tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply champty-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply champty-db --remote",
    "db:seed:local": "wrangler d1 execute champty-db --local --file=./drizzle/seed.sql",
    "db:seed:remote": "wrangler d1 execute champty-db --remote --file=./drizzle/seed.sql"
  },
  "dependencies": {
    "@react-router/cloudflare": "^7.13.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "drizzle-orm": "^0.45.1",
    "i18next": "^25.8.20",
    "i18next-http-backend": "^3.0.2",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-icons": "^5.6.0",
    "react-router": "7.13.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.15.3",
    "@cloudflare/workers-types": "^4.20250803.0",
    "@react-router/dev": "7.13.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.76.0"
  }
}
